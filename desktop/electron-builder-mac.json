{
  "appId": "com.localminidrama.desktop",
  "productName": "LocalMiniDrama",
  "directories": {
    "output": "release"
  },
  "files": [
    "main.js",
    "package.json",
    "backend-app/**/*",
    "node_modules/**/*",
    "!node_modules/.remotion/**"
  ],
  "asarUnpack": [
    "node_modules/better-sqlite3/**",
    "backend-app/tools/**",
    "node_modules/@remotion/compositor-*/**",
    "node_modules/@remotion/renderer/**",
    "node_modules/@remotion/bundler/**",
    "node_modules/esbuild/**",
    "node_modules/@esbuild/**",
    "node_modules/@rspack/binding/**",
    "node_modules/@rspack/binding*/**",
    "remotion-runtime/**"
  ],
  "extraResources": [
    {
      "from": "frontweb-dist",
      "to": "frontweb/dist",
      "filter": ["**/*"]
    },
    {
      "from": "../example_drama",
      "to": "example_drama",
      "filter": ["**/*"]
    },
    {
      "from": "ffmpeg-mac",
      "to": "ffmpeg",
      "filter": ["**/*"]
    },
    {
      "from": "remotion-runtime",
      "to": "remotion-runtime",
      "filter": ["**/*"]
    }
  ],
  "mac": {
    "target": [
      { "target": "dmg", "arch": ["x64", "arm64"] }
    ],
    "category": "public.app-category.entertainment",
    "icon": null,
    "identity": null
  },
  "dmg": {
    "title": "${productName} ${version}",
    "artifactName": "${productName}-${version}-mac-${arch}.dmg"
  }
}
